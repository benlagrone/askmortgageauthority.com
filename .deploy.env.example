# Copy to .deploy.env and review every value before using the deploy script.
#
# This file is for deploy orchestration only. It sits alongside `.env`, which is
# still used by Docker Compose for the container stack itself.

# Public hostnames served by host nginx. The first name is treated as canonical.
SITE_DOMAINS="askmortgageauthority.com www.askmortgageauthority.com"
SITE_PRIMARY_DOMAIN="askmortgageauthority.com"

# Current live site path used for full wp-content backups.
LIVE_WP_CONTENT_DIR="/var/www/askmortgageauthority.com/wp-content"
# Current live uploads path used for the final sync into ./data/uploads. If you
# leave this unset in .deploy.env, the deploy script defaults it to
# "${LIVE_WP_CONTENT_DIR}/uploads".
LIVE_UPLOADS_DIR="/var/www/askmortgageauthority.com/wp-content/uploads"

# Current live DB used for backups. Defaults can be inherited from `.env`, but
# setting them explicitly here is safer when the deploy script runs on the host.
LIVE_DB_HOST="127.0.0.1"
LIVE_DB_PORT="3306"
LIVE_DB_NAME="wordpress"
LIVE_DB_USER="wordpress"
LIVE_DB_PASSWORD="changeme"
# If you use a local Unix socket instead of TCP, set this and leave LIVE_DB_HOST
# as-is. The script will prefer the socket when present.
# LIVE_DB_SOCKET="/var/run/mysqld/mysqld.sock"

# The Docker-backed stack from this repo is exposed on this host port.
CONTAINER_PROXY_PORT="18020"

# Health check settings used before and after cutover.
HEALTHCHECK_PATH="/"
HEALTHCHECK_TIMEOUT_SECONDS="90"
# Set to 0 only for a local smoke test when DB access is not available.
BACKUP_DB_ENABLED="1"
# Optional: require this text to appear in the homepage HTML during smoke tests.
# SMOKE_TEST_EXPECTED_TEXT="Ask Mortgage Authority"

# rsync behavior for syncing the current live uploads into ./data/uploads.
RSYNC_DELETE="1"
# Optional exclude file for rsync.
# LIVE_RSYNC_EXCLUDES_FILE="/etc/ama/rsync-excludes.txt"

# Backup + local state locations inside this repo.
BACKUP_ROOT="./backups"
DEPLOY_STATE_DIR="./.deploy-state"

# Optional hooks that let you freeze the old site while the final sync and nginx
# cutover happen. Leave blank if you do not use them.
# LEGACY_ENABLE_MAINTENANCE_CMD="sudo -u www-data wp --path=/var/www/askmortgageauthority.com maintenance-mode activate"
# LEGACY_DISABLE_MAINTENANCE_CMD="sudo -u www-data wp --path=/var/www/askmortgageauthority.com maintenance-mode deactivate"
# POST_CUTOVER_CMD="docker compose exec -T wordpress wp cache flush --allow-root || true"
# POST_ROLLBACK_CMD="true"

# Host nginx automation. The deploy script manages two config files:
#   <HOST_NGINX_SITE_NAME>.legacy.conf
#   <HOST_NGINX_SITE_NAME>.container.conf
# and switches the active symlink in HOST_NGINX_ENABLED_DIR during cutover.
HOST_NGINX_SITE_NAME="askmortgageauthority"
HOST_NGINX_AVAILABLE_DIR="/etc/nginx/sites-available"
HOST_NGINX_ENABLED_DIR="/etc/nginx/sites-enabled"
HOST_NGINX_TEST_CMD="sudo nginx -t"
HOST_NGINX_RELOAD_CMD="sudo systemctl reload nginx"

# TLS paths used when rendering the managed host nginx configs.
HOST_NGINX_SSL_CERT="/etc/letsencrypt/live/askmortgageauthority.com/fullchain.pem"
HOST_NGINX_SSL_KEY="/etc/letsencrypt/live/askmortgageauthority.com/privkey.pem"
HOST_NGINX_CLIENT_MAX_BODY_SIZE="64M"

# Legacy pre-container WordPress runtime used for rollback and first bootstrap.
LEGACY_DOCROOT="/var/www/askmortgageauthority.com"
LEGACY_PHP_FPM_TARGET="unix:/run/php/php8.3-fpm.sock"
LEGACY_TRY_FILES="/index.php?\$args"

# Optional extra nginx directives. These files are appended inside the rendered
# server blocks if present.
# HOST_NGINX_COMMON_EXTRA_FILE="/etc/nginx/snippets/ama-common-extra.conf"
# HOST_NGINX_LEGACY_EXTRA_FILE="/etc/nginx/snippets/ama-legacy-extra.conf"
# HOST_NGINX_CONTAINER_EXTRA_FILE="/etc/nginx/snippets/ama-container-extra.conf"

# When enabled, a failed deploy that already switched traffic will automatically
# switch nginx back to the legacy config before exiting.
AUTO_ROLLBACK_ON_FAILURE="1"
