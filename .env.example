# Copy to .env and update with real values.
# The fortress control-plane deploy expects this file to live at the repo root
# and point the containerized WordPress runtime at the live database.
WORDPRESS_DB_HOST=host.docker.internal
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=changeme
WORDPRESS_DB_NAME=wordpress
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=false
# Optional: add WP_HOME/WP_SITEURL or other defines. Example:
# WORDPRESS_CONFIG_EXTRA=define('WP_HOME','https://askmortgageauthority.com');\ndefine('WP_SITEURL','https://askmortgageauthority.com');

# Optional WordPress REST credentials for automation/scripts that read or write
# live page content outside the container runtime.
# AMA_WP_BASE_URL=https://askmortgageauthority.com
# AMA_WP_USERNAME=your-wordpress-username
# AMA_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Only used if you enable the bundled MariaDB profile.
MARIADB_ROOT_PASSWORD=changeme

# Optional EspoCRM sync for forms (read by the mu-plugin in wp-content/mu-plugins).
# Keep disabled until any old standalone CRM script is removed to avoid double-submits.
# CRM_SYNC_ENABLED=false
# CRM_URL=https://crm.lecrowndevelopment.com
# CRM_API_KEY=replace-me
# AMA_CRM_LEAD_SOURCE=Website
# AMA_CRM_LEAD_SOURCE_FIELD=source
# AMA_CRM_BUSINESS_UNIT=Mortgage
# AMA_CRM_BUSINESS_UNIT_FIELD=businessUnit
# AMA_CRM_PRODUCT_TYPE=Mortgage
# AMA_CRM_PRODUCT_TYPE_FIELD=productType
# AMA_CRM_WPFORMS_IDS=1020
# AMA_CRM_FORMINATOR_IDS=311
